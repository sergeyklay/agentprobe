# Please do not use this ignore file to define platform specific files.
#
# For these purposes create a global .gitignore file, which is a list of rules
# for ignoring files in every Git repository on your computer.
#
# https://help.github.com/articles/ignoring-files/#create-a-global-gitignore

# Do not add trailing '/'s to directory names, they skip symlinks.

# Experiment results (generated by orchestrator, not source)
/experiments/*/results

# Archive run data (large logs and diffs)
/archive/*/logs
/archive/*/diffs

# Temporary worktrees
/tmp/agentprobe-runs
