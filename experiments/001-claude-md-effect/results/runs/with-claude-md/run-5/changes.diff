+          // Check if the variable has an explicitly annotated type that is nullable.
+          // If the declared type is nullable but the current type is not, it means
+          // type narrowing has occurred (through control flow or assignment).
+          // Be conservative in nested scopes where narrowing might be unreliable.
+          if (node.expression.type === AST_NODE_TYPES.Identifier) {
+            const declaration = getDeclaration(services, node.expression);
+            if (
+              declaration &&
+              ts.isVariableDeclaration(declaration) &&
+              declaration.type != null
+            ) {
+              const declaredType = checker.getTypeFromTypeNode(
+                declaration.type,
+              );
+              // Only skip reporting if we have an explicitly annotated nullable type
+              // that has been narrowed to non-nullable, AND we're in a nested scope
+              if (declaredType && isNullableType(declaredType)) {
+                // Check if we're in a nested scope by looking at parent nodes
+                let parent = node.parent;
+                let inNestedScope = false;
+                while (parent) {
+                  // Check if we're inside a block statement (if, while, for, etc.)
+                  if (
+                    parent.type === AST_NODE_TYPES.BlockStatement ||
+                    parent.type === AST_NODE_TYPES.ArrowFunctionExpression ||
+                    parent.type === AST_NODE_TYPES.FunctionExpression ||
+                    parent.type === AST_NODE_TYPES.IfStatement ||
+                    parent.type === AST_NODE_TYPES.WhileStatement ||
+                    parent.type === AST_NODE_TYPES.ForStatement ||
+                    parent.type === AST_NODE_TYPES.ForInStatement ||
+                    parent.type === AST_NODE_TYPES.ForOfStatement ||
+                    parent.type === AST_NODE_TYPES.SwitchStatement ||
+                    parent.type === AST_NODE_TYPES.TryStatement ||
+                    parent.type === AST_NODE_TYPES.CatchClause
+                  ) {
+                    inNestedScope = true;
+                    break;
+                  }
+                  // Stop when we reach a function or program boundary
+                  if (
+                    parent.type === AST_NODE_TYPES.FunctionDeclaration ||
+                    parent.type === AST_NODE_TYPES.Program
+                  ) {
+                    break;
+                  }
+                  parent = parent.parent;
+                }
+
+                if (inNestedScope) {
+                  return;
+                }
+              }
+            }
+          }
